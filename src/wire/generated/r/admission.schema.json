{
  "$comment": "GENERATED by tools/abnf-gen — DO NOT EDIT. Source of truth: specs/grammar/admission.abnf",
  "lower-hex": {
    "pattern": "^[0-9a-f]$"
  },
  "request-id": {
    "pattern": "^[0-9a-f]{32}$"
  },
  "fed-prefix": {
    "pattern": "^federated\\.$",
    "enum": [
      "federated."
    ]
  },
  "scope-tail": {
    "pattern": "^\\.>$",
    "enum": [
      ".>"
    ]
  },
  "requested-scope": {
    "pattern": "^federated\\.[a-z][a-z0-9]*(?:-[a-z0-9]+)*\\.>$"
  },
  "st-pending": {
    "pattern": "^PENDING$",
    "enum": [
      "PENDING"
    ]
  },
  "st-admitted": {
    "pattern": "^ADMITTED$",
    "enum": [
      "ADMITTED"
    ]
  },
  "st-rejected": {
    "pattern": "^REJECTED$",
    "enum": [
      "REJECTED"
    ]
  },
  "st-revoked": {
    "pattern": "^REVOKED$",
    "enum": [
      "REVOKED"
    ]
  },
  "st-departed": {
    "pattern": "^DEPARTED$",
    "enum": [
      "DEPARTED"
    ]
  },
  "admission-status": {
    "pattern": "^(?:PENDING|ADMITTED|REJECTED|REVOKED|DEPARTED)$",
    "enum": [
      "PENDING",
      "ADMITTED",
      "REJECTED",
      "REVOKED",
      "DEPARTED"
    ]
  },
  "decision": {
    "pattern": "^(?:admit|reject)$",
    "enum": [
      "admit",
      "reject"
    ]
  },
  "base64-char": {
    "pattern": "^[A-Za-z0-9+\\/]$"
  },
  "base64": {
    "pattern": "^[A-Za-z0-9+\\/]+=*$"
  },
  "ed25519-pubkey": {
    "pattern": "^[A-Za-z0-9+\\/]+=*$"
  },
  "ed25519-signature": {
    "pattern": "^[A-Za-z0-9+\\/]+=*$"
  },
  "sealed-secret": {
    "pattern": "^[A-Za-z0-9+\\/]+=*$"
  },
  "base64url-char": {
    "pattern": "^[A-Za-z0-9\\-_]$"
  },
  "leaf-psk": {
    "pattern": "^[A-Za-z0-9\\-_]+$"
  },
  "leaf-user": {
    "pattern": "^[A-Za-z0-9\\-_\\/.]+$"
  }
}
