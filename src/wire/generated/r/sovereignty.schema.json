    "enum": [
      "true",
      "false"
    ]
  },
  "model-class": {
    "pattern": "^(?:local-only|frontier|any)$",
    "enum": [
      "local-only",
      "frontier",
      "any"
    ]
  },
  "sovereignty-mode": {
    "pattern": "^(?:open|selective|strict|bidding)$",
    "enum": [
      "open",
      "selective",
      "strict",
      "bidding"
    ]
  },
  "nak-reason-code": {
    "pattern": "^compliance_block:(?:classification-mismatch|residency-violation|unknown-principal|scope-exceeded|chain-invalid|partner-unknown)$"
  },
  "reason-token": {
    "pattern": "^(?:classification-mismatch|residency-violation|unknown-principal|scope-exceeded|chain-invalid|partner-unknown)$",
    "enum": [
      "classification-mismatch",
      "residency-violation",
      "unknown-principal",
      "scope-exceeded",
      "chain-invalid",
      "partner-unknown"
    ]
  }
